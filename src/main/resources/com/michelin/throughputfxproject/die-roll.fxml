<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<BorderPane prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/11.0.14-internal"
            stylesheets="@css/throughput.css"  xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.michelin.throughputfxproject.controllers.DieController" onMouseClicked="#closeCardWindow">
    <top>
        <Label fx:id="dieHeaderText" prefHeight="104.0" prefWidth="600.0" text="Some header text about dice roll of 1"
               wrapText="true" BorderPane.alignment="CENTER" styleClass="die-header">
        </Label>
    </top>
    <center>
        <ImageView fx:id="dieImage" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
            <Image url="@icons/die_1.png"/>
        </ImageView>
    </center>
    <bottom>
        <Label fx:id="dieText" alignment="TOP_LEFT" prefHeight="104.0" prefWidth="600.0"
               text="Some text about dice roll of 1" wrapText="true" BorderPane.alignment="CENTER"
               styleClass="die-text">
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0"/>
            </BorderPane.margin>
        </Label>
    </bottom>
</BorderPane>
