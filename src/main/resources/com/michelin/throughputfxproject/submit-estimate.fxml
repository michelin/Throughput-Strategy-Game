<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.michelin.throughputfxproject.controllers.EstimateController">
    <TextArea editable="false" focusTraversable="false" mouseTransparent="true" styleClass="read-only-textarea" stylesheets="@throughput.css" text="Enter how many work items you think you can finish. Unfinished work items count as WIP. This is the number you start with in (or add to) your backlog. '10' will add 10 work items to the backlog." wrapText="true" />
    <TextField fx:id="estimateResponseText" text="10" />
    <Button fx:id="estimateButton" defaultButton="true" onAction="#applyEstimate" text="Submit Estimate" />
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <VBox.margin>
        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
    </VBox.margin>
</VBox>
